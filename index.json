<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VexTiers Rankings</title>
<style>
/* --- BASE STYLING (IMAGE SCHEME) --- */
body { 
  margin: 0; 
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
  background: #0f121a; /* Deep navy background */
  color: #fff; 
}

.container { max-width: 1000px; margin: 0 auto; padding: 40px 20px; }

h1 { 
  text-align: center; 
  color: #7a1d23; /* Dark red title */
  font-size: 2.5rem; 
  text-transform: uppercase; 
  letter-spacing: 2px;
  margin-bottom: 30px;
  font-weight: 900;
}

/* --- TABS --- */
.tabs { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 25px; justify-content: center; }

.tab { 
  padding: 8px 16px; 
  border-radius: 8px; 
  background: #1c212b; 
  cursor: pointer; 
  border: 1px solid #333; 
  color: #b0b0b0;
  transition: 0.2s;
  font-size: 0.9rem;
}

.tab.active { 
  background: #7a1d23; 
  border-color: #a02830; 
  color: #fff; 
  font-weight: bold; 
}

/* --- SEARCH --- */
input {
  width: 100%; 
  padding: 15px; 
  margin-bottom: 30px;
  border-radius: 12px; 
  border: 1px solid #333;
  background: #1c212b; 
  color: #fff;
  box-sizing: border-box;
  font-size: 1rem;
  outline: none;
}

/* --- OVERALL RANKINGS (SLANTED HIGHLIGHTS) --- */
.player-card {
  background: #1c212b; 
  display: flex;
  align-items: center;
  border-radius: 12px;
  margin-bottom: 12px; 
  border: 1px solid #2a313d;
  cursor: pointer; 
  transition: transform 0.1s;
  overflow: hidden;
}
.player-card:hover { transform: scale(1.01); border-color: #444; }

.rank-badge {
  font-size: 2rem;
  font-weight: 900;
  font-style: italic;
  width: 70px;
  height: 75px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #21262d; /* Default background */
  color: #fff;
  flex-shrink: 0;
}

/* Gold, Silver, Bronze highlights */
.rank-1 .rank-badge { background: #f2ce5a; color: #000; }
.rank-2 .rank-badge { background: #8b949e; color: #000; }
.rank-3 .rank-badge { background: #cd7f32; color: #fff; }

.skin-display {
  width: 70px;
  height: 75px;
  background: #0d1017;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  overflow: hidden;
  border-right: 1px solid #333;
}
.skin-display img { 
  width: 100%; 
  height: auto; 
  image-rendering: pixelated; 
}

.player-main { flex-grow: 1; padding-left: 20px; }
.player-name { font-size: 1.3rem; font-weight: bold; }
.player-title-line { color: #b0b0b0; font-size: 0.85rem; margin-top: 2px; }

.region-tag {
  background: #7a1d23;
  color: white;
  padding: 4px 10px;
  border-radius: 5px;
  font-size: 0.75rem;
  font-weight: bold;
  margin-right: 15px;
}

.card-tiers { display: flex; gap: 5px; padding-right: 20px; }
.tag-mini { background: #2a313d; border: 1px solid #444; padding: 3px 7px; border-radius: 5px; font-size: 10px; color: #ccc; }

/* --- TIER GRID (GAMEMODE VIEW) --- */
.tier-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); gap: 20px; }
.tier-column { background: #1c212b; border-radius: 12px; padding: 15px; border: 1px solid #333; }
.tier-header { text-align: center; font-weight: 900; padding: 10px; border-radius: 8px; margin-bottom: 12px; text-transform: uppercase; font-size: 0.9rem; }
.tier-1 { background: #f2ce5a; color: #000; }
.tier-2 { background: #8b949e; color: #000; }
.tier-3 { background: #cd7f32; color: #fff; }
.tier-player { padding: 10px; margin-bottom: 8px; background: #0f121a; border-radius: 8px; text-align: center; font-size: 0.9rem; cursor: pointer; }

/* --- MODAL (MENU) --- */
.modal { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.92); display: flex; justify-content: center; align-items: center; z-index: 1000; }
.hidden { display: none; }
.modal-content { background: #1c212b; padding: 40px 30px; border-radius: 24px; width: 380px; text-align: center; border: 1px solid #333; position: relative; box-shadow: 0 10px 40px rgba(0,0,0,0.8); }
#closeModal { position: absolute; top: 15px; right: 20px; cursor: pointer; color: #888; font-size: 1.5rem; }

.modal-skin-container {
  background: radial-gradient(circle, #2a313d 0%, #0d1017 100%);
  border-radius: 15px;
  padding: 20px;
  display: inline-block;
  border: 1px solid #444;
  margin-bottom: 15px;
}
.avatar-modal { height: 180px; width: auto; image-rendering: pixelated; filter: drop-shadow(0 10px 15px rgba(0,0,0,0.6)); }

.modal-name { font-size: 24px; font-weight: bold; margin: 10px 0 5px; }
.modal-sub { color: #b0b0b0; font-size: 14px; margin-bottom: 10px; }
.modal-points { color: #f2ce5a; font-size: 20px; font-weight: bold; margin-bottom: 20px; }

.tag-container { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-top: 15px; }
.tag-big { background: #2a313d; color: #d0d0d0; padding: 6px 12px; border-radius: 8px; font-size: 0.8rem; border: 1px solid #444; font-weight: bold; }
</style>
</head>

<body>

<div class="container">
  <h1>Vextiers Rankings</h1>
  <div id="tabs" class="tabs"></div>
  <input id="search" placeholder="Search for a player name...">
  <div id="players"></div>
</div>

<div id="playerModal" class="modal hidden">
  <div class="modal-content">
    <span id="closeModal">×</span>
    <div id="modalBody"></div>
  </div>
</div>

<script>
const tabs = ["Overall", "Vanilla", "UHC", "Pot", "SMP", "Sword", "Axe", "Mace", "Diamond SMP", "NethPot", "Cart PvP", "Creeper", "Bridge", "Bow"];
let currentTab = "Overall";

// Data
const playersData = {
  Sword: [
    { name: "Vexilz_", region: "EU", points: 200, tiers: ["HT1 Sword"] },
    { name: "MR_sl0th", region: "EU", points: 150, tiers: ["LT1 Sword"] },
    { name: "Mr_grayy", region: "EU", points: 100, tiers: ["HT2 Sword"] }
  ],
  Pot: [
    { name: "Vexilz_", region: "EU", points: 300, tiers: ["HT1 Pot"] },
    { name: "Mr_grayy", region: "EU", points: 150, tiers: ["LT1 Pot"] }
  ],
  UHC: [
    { name: "Vexilz_", region: "EU", points: 205, tiers: ["LT1 UHC"] }
  ]
};

const playersDiv = document.getElementById("players");
const searchInput = document.getElementById("search");
const modal = document.getElementById("playerModal");
document.getElementById("closeModal").onclick = () => modal.classList.add("hidden");

function openPlayerModal(p, rank) {
  // Generate Tier Badges
  const tagsHtml = p.tiers.map(t => `<span class="tag-big">${t}</span>`).join("");
  
  document.getElementById("modalBody").innerHTML = `
    <div class="modal-skin-container">
      <img class="avatar-modal" 
           src="https://minotar.net/armor/body/${p.name}/150.png" 
           onerror="this.src='https://minotar.net/armor/body/Steve/150.png'">
    </div>
    <div class="modal-name">${p.name}</div>
    <div class="modal-sub">${p.region} • Rank #${rank}</div>
    <div class="modal-points">${p.points} Combat Points</div>
    <div class="tag-container">
      ${tagsHtml}
    </div>
  `;
  modal.classList.remove("hidden");
}

function renderTabs() {
  const tabsDiv = document.getElementById("tabs");
  tabsDiv.innerHTML = "";
  tabs.forEach(t => {
    const btn = document.createElement("div");
    btn.className = "tab" + (t === currentTab ? " active" : "");
    btn.textContent = t;
    btn.onclick = () => { currentTab = t; renderTabs(); render(); };
    tabsDiv.appendChild(btn);
  });
}

function mergeOverall() {
  const merged = [];
  Object.values(playersData).flat().forEach(p => {
    const ex = merged.find(m => m.name === p.name);
    if (ex) {
      ex.points += p.points;
      ex.tiers = [...new Set([...ex.tiers, ...p.tiers])];
    } else merged.push({ ...p });
  });
  return merged;
}

function render() {
  let displayPlayers = currentTab === "Overall" ? mergeOverall() : [...(playersData[currentTab] || [])];
  const search = searchInput.value.toLowerCase();
  if (search) displayPlayers = displayPlayers.filter(p => p.name.toLowerCase().includes(search));

  displayPlayers.sort((a, b) => b.points - a.points);
  playersDiv.innerHTML = "";

  if (currentTab === "Overall") {
    displayPlayers.forEach((p, i) => {
      const rank = i + 1;
      const rankClass = rank <= 3 ? `rank-${rank}` : "";
      const div = document.createElement("div");
      div.className = `player-card ${rankClass}`;
      div.onclick = () => openPlayerModal(p, rank);
      
      div.innerHTML = `
        <div class="rank-badge">${rank}.</div>
        <div class="skin-display">
          <img src="https://minotar.net/armor/body/${p.name}/100.png" onerror="this.src='https://minotar.net/armor/body/Steve/100.png'">
        </div>
        <div class="player-main">
          <div class="player-name">${p.name}</div>
          <div class="player-title-line">Combat Master (${p.points} points)</div>
        </div>
        <div class="region-tag">${p.region}</div>
        <div class="card-tiers">${p.tiers.slice(0, 5).map(t => `<span class="tag-mini">${t}</span>`).join('')}</div>
      `;
      playersDiv.appendChild(div);
    });
  } else {
    // GAMEMODE GRID
    const groups = { 1: [], 2: [], 3: [], 4: [], 5: [] };
    displayPlayers.forEach(p => {
      const match = p.tiers[0].match(/T(\d)/);
      if (match) groups[match[1]].push(p);
    });

    const grid = document.createElement("div");
    grid.className = "tier-grid";
    Object.keys(groups).forEach(tier => {
      if (groups[tier].length === 0) return;
      const col = document.createElement("div");
      col.className = "tier-column";
      col.innerHTML = `<div class="tier-header tier-${tier}">Tier ${tier}</div>`;
      groups[tier].forEach(p => {
        const div = document.createElement("div");
        div.className = "tier-player";
        div.textContent = p.name;
        div.onclick = () => openPlayerModal(p, displayPlayers.indexOf(p) + 1);
        col.appendChild(div);
      });
      grid.appendChild(col);
    });
    playersDiv.appendChild(grid);
  }
}

renderTabs();
render();
</script>
</body>
</html>
